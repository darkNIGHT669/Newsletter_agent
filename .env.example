# Pick one provider: anthropic | openai | gemini
LLM_PROVIDER=anthropic
LLM_MODEL=claude-3-5-sonnet-20241022

# Only the key matching LLM_PROVIDER needs to be set
ANTHROPIC_API_KEY=your_anthropic_key_here
OPENAI_API_KEY=your_openai_key_here
GOOGLE_API_KEY=your_google_key_here

# Optional: real web search. If omitted, the agent falls back to an
# offline mock corpus so the whole app still runs end-to-end.
TAVILY_API_KEY=your_tavily_key_here

# Where paused/completed agent runs are checkpointed. A real file path
# (default) means a Human-in-the-Loop run survives an app restart — note
# the thread ID shown in the sidebar before closing, paste it into "Resume
# a paused session" later to pick it back up. Set to ":memory:" for
# ephemeral behavior (e.g. in CI, where a leftover .sqlite file is noise).
CHECKPOINT_DB_PATH=checkpoints.sqlite
